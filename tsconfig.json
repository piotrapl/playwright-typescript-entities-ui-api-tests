{
  "compilerOptions": {
    /* Language and environment */
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021", "DOM"],
    "moduleResolution": "node",
    "types": ["node", "@playwright/test"],

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Project structure */
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Quality */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "tests",
    "pages",
    "flows",
    "api",
    "assertions",
    "data",
    "fixtures",
    "utils",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "playwright-report",
    "test-results"
  ]
}